# ROS 2 workspaces
# Ignoring the build, install, and log directories which are generated by colcon.
/build/
/install/
/log/

# Python
# Ignoring Python cache files, compiled files, and distribution folders.
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# IDE and editor specific files
# Ignoring configuration files from common editors and IDEs.
.vscode/
.idea/
*.swp
*.swo

# Other generated files
# Ignoring other temporary or generated files.
*.DS_Store